.status-bar { width: 100%; background-color: var(--bg-warm); }
.header { padding: 32rpx 40rpx 40rpx; background-color: var(--bg-warm); position: sticky; top: 0; z-index: 10; }
.header-content { display: flex; justify-content: space-between; align-items: flex-end; }
.header-left { display: flex; flex-direction: column; }
.date-title { font-size: 48rpx; font-weight: 800; color: var(--text-primary); letter-spacing: -1rpx; margin-bottom: 8rpx; }
.date-subtitle { font-size: 28rpx; color: var(--text-secondary); font-weight: 500; }
.header-right { width: 88rpx; height: 88rpx; background: #eff6ff; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 12rpx rgba(59,130,246,0.1); transition: all 0.2s;}
.header-right:active { transform: scale(0.95); }
.add-icon { width: 44rpx; height: 44rpx; }

.task-list { padding: 0 40rpx; display: flex; flex-direction: column; gap: 32rpx; }
.task-card { position: relative; overflow: hidden; background: var(--card-bg); border-radius: var(--radius-card); padding: 40rpx; box-shadow: 0 16rpx 40rpx -12rpx rgba(0,0,0,0.05); display: flex; gap: 32rpx; align-items: center; border: 1rpx solid rgba(255,255,255,0.8); }
.task-color-bar { position: absolute; left: 0; top: 0; bottom: 0; width: 12rpx; }
.bg-slate { background-color: #94a3b8; }
.bg-blue { background-color: #3b82f6; }
.bg-orange { background-color: #f97316; }

.task-main { flex: 1; display: flex; flex-direction: column; gap: 16rpx; padding-right: 20rpx; }
.task-title { font-size: 34rpx; font-weight: 600; color: var(--text-primary); }
.task-info { display: flex; justify-content: space-between; align-items: center; }
.task-time { font-size: 26rpx; font-weight: 500; color: var(--text-secondary); }
.task-status { font-size: 22rpx; font-weight: 600; padding: 6rpx 20rpx; border-radius: 40rpx; }
.status-done { background: #f1f5f9; color: #64748b; }
.status-doing { background: #eff6ff; color: #3b82f6; }
.status-todo { background: #fff7ed; color: #f97316; }

/* 删除按钮样式 */
.delete-btn { position: absolute; right: 24rpx; top: 24rpx; width: 48rpx; height: 48rpx; text-align: center; line-height: 44rpx; color: #cbd5e1; font-size: 40rpx; border-radius: 50%; }
.delete-btn:active { background: #fef2f2; color: #ef4444; }
.empty-state { text-align: center; padding: 60rpx 0; color: #94a3b8; font-size: 28rpx; }

/* 新增日程弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6); /* 遮罩颜色加深一点，更有沉浸感 */
  z-index: 1000; /* 确保 z-index 高于 custom-tab-bar 的 100 */
  animation: fadeIn 0.3s;
  backdrop-filter: blur(2px); /* 增加毛玻璃效果，更高级 */
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 48rpx 48rpx 0 0;
  /* 关键优化：padding-bottom 要考虑 TabBar 高度 + iPhone 安全距离 */
  padding: 48rpx 40rpx calc(env(safe-area-inset-bottom) + 60rpx); 
  z-index: 1001; /* 确保在遮罩层之上 */
  box-shadow: 0 -12rpx 40rpx rgba(0, 0, 0, 0.15);
  animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.modal-header { font-size: 36rpx; font-weight: 700; margin-bottom: 40rpx; text-align: center; color: var(--text-primary); }
.modal-input { background: #f8fafc; border: 1rpx solid #e2e8f0; padding: 28rpx 32rpx; border-radius: 24rpx; margin-bottom: 24rpx; font-size: 30rpx; }
.modal-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx; 
}
.modal-btn { flex: 1; padding: 26rpx; text-align: center; border-radius: 60rpx; font-size: 32rpx; font-weight: 600; }
.cancel { background: #f1f5f9; color: #64748b; }
.confirm { background: var(--primary); color: #fff; box-shadow: 0 8rpx 24rpx rgba(59,130,246,0.3); }

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }