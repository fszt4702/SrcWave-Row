.profile-page { min-height: 100vh; background-color: var(--bg-warm); padding-bottom: 140rpx; box-sizing: border-box; }
.status-bar { width: 100%; }
.profile-header { display: flex; flex-direction: column; align-items: center; padding: 80rpx 40rpx 60rpx; }
.avatar-circle { width: 180rpx; height: 180rpx; background: var(--primary-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 8rpx solid #fff; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04); margin-bottom: 24rpx; }
.avatar-icon { width: 110rpx; height: 110rpx; }
.profile-nickname { font-size: 36rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 16rpx; }
.profile-tag { padding: 12rpx 32rpx; background: #f1f5f9; border-radius: 80rpx; font-size: 20rpx; color: var(--text-secondary); font-weight: 600; }