.calendar-header { padding: 20rpx 40rpx 40rpx; background: #ffffff; border-radius: 0 0 48rpx 48rpx; box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.03); }
.month-title { font-size: 36rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 32rpx; text-align: center; }
.week-row { display: flex; justify-content: space-between; margin-bottom: 24rpx; }
.week-day { flex: 1; text-align: center; font-size: 24rpx; color: var(--text-light); font-weight: 600; }
.date-row { display: flex; justify-content: space-between; }
.date-cell { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 80rpx; position: relative; border-radius: 20rpx; transition: all 0.2s; }
.date-cell.active { background: var(--primary); color: #fff; box-shadow: 0 8rpx 20rpx rgba(59,130,246,0.3); }
.date-num { font-size: 32rpx; font-weight: 600; z-index: 2; }
.date-cell:not(.active) .date-num { color: var(--text-primary); }
.date-dot { width: 8rpx; height: 8rpx; background: #fff; border-radius: 50%; position: absolute; bottom: 8rpx; }
.date-cell:not(.active) .date-dot { background: var(--primary); }
.timeline { padding: 60rpx 40rpx; }
.timeline-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 40rpx; }
.timeline-item { display: flex; margin-bottom: 40rpx; min-height: 120rpx; }
.time-label { width: 140rpx; font-size: 24rpx; font-weight: 600; color: var(--text-secondary); margin-top: 6rpx; }
.timeline-content { flex: 1; display: flex; position: relative; padding-bottom: 40rpx; }
.timeline-content::before { content: ''; position: absolute; left: 15rpx; top: 40rpx; bottom: 0; width: 2rpx; background: #e2e8f0; z-index: 1; }
.timeline-item:last-child .timeline-content::before { display: none; }
.timeline-dot { width: 32rpx; height: 32rpx; border-radius: 50%; border: 6rpx solid #fff; position: absolute; left: 0; top: 0; z-index: 2; box-shadow: 0 0 0 2rpx #e2e8f0; }
.timeline-card { margin-left: 60rpx; background: #fff; padding: 28rpx 32rpx; border-radius: 24rpx; flex: 1; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.03); border: 1rpx solid #f1f5f9; display: flex; flex-direction: column; gap: 12rpx; }
.tl-title { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.tl-status { font-size: 24rpx; font-weight: 500; }
.text-slate { color: #64748b; } .text-blue { color: #3b82f6; } .text-orange { color: #f97316; }
.bg-blue { background-color: #3b82f6; }