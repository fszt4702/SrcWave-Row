.ai-page { min-height: 100vh; background-color: var(--bg-warm); display: flex; flex-direction: column; padding-bottom: 140rpx; box-sizing: border-box; }
.status-bar { width: 100%; }
.ai-profile { margin: 16rpx 40rpx 8rpx; padding: 28rpx 32rpx; background: var(--card-bg); border-radius: var(--radius-card); display: flex; align-items: center; gap: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02); }
.ai-avatar-wrap { position: relative; }
.ai-avatar { width: 80rpx; height: 80rpx; background: linear-gradient(135deg, #3b82f6, #60a5fa); border-radius: 50%; padding: 16rpx; box-sizing: border-box; }
.status-indicator { position: absolute; bottom: 0; right: 0; width: 24rpx; height: 24rpx; background: #10b981; border: 4rpx solid #fff; border-radius: 50%; }
.ai-info { display: flex; flex-direction: column; }
.ai-name { font-size: 30rpx; font-weight: 700; color: var(--text-primary); }
.ai-desc { font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }
.chat-box { flex: 1; height: 0; }
.chat-padding { padding: 32rpx 40rpx 200rpx; display: flex; flex-direction: column; gap: 40rpx; }
.chat-msg { display: flex; gap: 20rpx; align-items: flex-start; }
.msg-user { flex-direction: row-reverse; }
.chat-avatar-small { width: 56rpx; height: 56rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.bg-primary { background-color: var(--primary); padding: 12rpx; box-sizing: border-box;}
.chat-bubble { max-width: 75%; padding: 24rpx 32rpx; font-size: 28rpx; line-height: 1.6; }
.bubble-ai { background: var(--card-bg); color: var(--text-primary); border-radius: 8rpx 32rpx 32rpx 32rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02); }
.bubble-user { background: var(--primary); color: #ffffff; border-radius: 32rpx 8rpx 32rpx 32rpx; box-shadow: 0 8rpx 24rpx rgba(59,130,246,0.25); }
.ai-input-area { position: fixed; bottom: 100rpx; left: 0; right: 0; padding: 20rpx 40rpx 40rpx; background: linear-gradient(to top, rgba(253,252,251,1) 70%, rgba(253,252,251,0)); z-index: 10; }
.quick-actions { display: flex; gap: 16rpx; overflow-x: auto; margin-bottom: 24rpx; }
.quick-btn { white-space: nowrap; background: var(--card-bg); padding: 12rpx 24rpx; border-radius: 60rpx; font-size: 24rpx; color: var(--text-secondary); border: 1rpx solid #e2e8f0; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02); }
.input-wrap { display: flex; align-items: center; gap: 16rpx; background: var(--card-bg); padding: 16rpx 24rpx; border-radius: 60rpx; box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06); border: 1rpx solid rgba(226,232,240,0.8); }
.icon-btn { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; }
.icon-svg { width: 40rpx; height: 40rpx; }
.input-element { flex: 1; font-size: 28rpx; height: 64rpx; }
.send-btn { background: #e2e8f0; transition: all 0.3s; }
.send-btn.active { background: var(--primary); box-shadow: 0 4rpx 12rpx rgba(59,130,246,0.4); }