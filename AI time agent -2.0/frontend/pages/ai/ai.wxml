<view class="ai-page">
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
  
  <view class="ai-profile">
    <view class="ai-avatar-wrap">
      <image class="ai-avatar" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='white' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpath d='M12 2l2.4 7.2L22 12l-7.6 2.8L12 22l-2.4-7.2L2 12l7.6-2.8L12 2z'%3E%3C/path%3E%3C/svg%3E" mode="widthFix" />
      <view class="status-indicator"></view>
    </view>
    <view class="ai-info">
      <text class="ai-name">FlowTime Agent</text>
      <text class="ai-desc">贴心响应，动态重组</text>
    </view>
  </view>

  <scroll-view class="chat-box" scroll-y scroll-into-view="{{scrollToMessage}}">
    <view class="chat-padding">
      <block wx:for="{{messages}}" wx:key="index">
        <view id="msg-{{index}}" class="chat-msg {{item.role === 'ai' ? 'msg-ai' : 'msg-user'}}">
          <view wx:if="{{item.role === 'ai'}}" class="chat-avatar-small bg-primary">
            <image src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='white' stroke-width='2'%3E%3Cpath d='M12 2l2.4 7.2L22 12l-7.6 2.8L12 22l-2.4-7.2L2 12l7.6-2.8L12 2z'%3E%3C/path%3E%3C/svg%3E" mode="aspectFit" />
          </view>
          <view class="chat-bubble {{item.role === 'ai' ? 'bubble-ai' : 'bubble-user'}}">
            <text class="bubble-text">{{item.content}}</text>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>

  <view class="ai-input-area">
    <view class="quick-actions">
      <view class="quick-btn" bindtap="quickAction" data-text="😫 实验课拖堂，快累瘫了">😫 实验拖堂累瘫了</view>
      <view class="quick-btn" bindtap="quickAction" data-text="📢 导员通知21点开紧急班会">📢 临时紧急班会</view>
    </view>
    <view class="input-wrap">
      <view class="icon-btn"><image class="icon-svg" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2394a3b8' stroke-width='2'%3E%3Ccircle cx='12' cy='12' r='10'%3E%3C/circle%3E%3Cpath d='M12 16v-4'%3E%3C/path%3E%3Cpath d='M12 8h.01'%3E%3C/path%3E%3C/svg%3E" mode="widthFix" /></view>
      <input class="input-element" value="{{inputValue}}" bindinput="onInput" placeholder="告诉Agent突发状况..." confirm-type="send" bindconfirm="sendMessage" />
      <view class="icon-btn send-btn {{inputValue ? 'active' : ''}}" bindtap="sendMessage">
        <image class="icon-svg" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='white' stroke-width='2'%3E%3Cline x1='22' y1='2' x2='11' y2='13'%3E%3C/line%3E%3Cpolygon points='22 2 15 22 11 13 2 9 22 2'%3E%3C/polygon%3E%3C/svg%3E" mode="widthFix" />
      </view>
    </view>
  </view>
</view>