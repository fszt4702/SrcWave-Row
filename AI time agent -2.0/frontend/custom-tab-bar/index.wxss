.tab-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 100rpx; display: flex; background: rgba(255,255,255,0.92); backdrop-filter: blur(10px); border-top: 1rpx solid #f1f5f9; padding-bottom: env(safe-area-inset-bottom); z-index: 100; }
.tab-item { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #94a3b8; transition: all 0.2s; }
.tab-item.active { color: #3b82f6; }
.tab-icon { width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; margin-bottom: 4rpx; }
.icon-img { width: 44rpx; height: 44rpx; }
.tab-text { font-size: 20rpx; line-height: 1.2; }